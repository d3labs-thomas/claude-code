{
    "mcpServers": {
        "serena": {
            "type": "stdio",
            "command": "/Users/thomas/.local/bin/uvx",
            "args": [
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--context",
                "ide-assistant"
            ],
            "env": {}
        },
        "context7": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ],
            "env": {}
        },
        "playwright": {
            "command": "npx",
            "args": [
                "@playwright/mcp@latest"
            ]
        },
        "figma": {
            "type": "http",
            "url": "https://mcp.figma.com/mcp"
        }
    }
}